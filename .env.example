# FloxBot Environment Variables
# Copy to .env and fill in values

# LLM Backends
ANTHROPIC_API_KEY=
FLOXBOT_CLAUDE_MODEL=claude-sonnet-4-6
FLOXBOT_CODEX_API_KEY=
FLOXBOT_CODEX_MODEL=claude-sonnet-4-6

# Infrastructure
FLOXBOT_KAFKA_BOOTSTRAP=localhost:9092
FLOXBOT_REDIS_URL=redis://localhost:6379/0
FLOXBOT_DATABASE_URL=postgresql://localhost:5432/floxbot

# API
FLOXBOT_API_HOST=0.0.0.0
FLOXBOT_API_PORT=8000

# Channel Adapters
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=
SENDGRID_API_KEY=

# Escalation
INTERCOM_API_KEY=
